---
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="home" class="relative bg-accent overflow-hidden">
  <!-- Decorative background shape -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent via-white to-accent opacity-60" aria-hidden="true"></div>

  <div class="relative container mx-auto px-4 max-w-6xl py-16 md:py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Text Content -->
      <div class="flex flex-col gap-6">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 self-start">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" aria-hidden="true"></span>
          <span class="text-xs font-semibold text-green-700 bg-green-50 border border-green-200 rounded-full px-3 py-1">
            {t('hero.badge')}
          </span>
        </div>

        <!-- Heading -->
        <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-primary leading-tight">
          {t('hero.title')}
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed max-w-lg">
          {t('hero.subtitle')}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href="tel:9095912273" class="btn-primary">
            {t('hero.cta.primary')}
          </a>
          <a href="#services" class="btn-outline">
            {t('hero.cta.secondary')}
          </a>
        </div>

        <!-- Quick Info -->
        <div class="flex flex-wrap gap-4 pt-4 border-t border-gray-200">
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Chino, CA 91710
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            (909) 591-CARE
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-md">
          <!-- Decorative circle behind image -->
          <div class="absolute inset-4 rounded-full bg-primary/10" aria-hidden="true"></div>
          <img
            src="/images/Dr_Darlene_Sanchez_patient.jpg"
            alt="Dr. Darlene O. Sanchez with a patient at Loving Hands Animal Hospital"
            class="relative rounded-2xl shadow-2xl w-full object-cover aspect-[4/5]"
            width="400"
            height="500"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>
</section>
