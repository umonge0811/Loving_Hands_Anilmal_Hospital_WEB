---
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="home"
  class="relative overflow-hidden min-h-[600px] md:min-h-[700px]"
>
  <!-- Decorative background shape -->
  <!-- Slideshow de fondo -->
  <div id="hero-slideshow" class="absolute inset-0 z-0">
    {
      [1, 2, 3, 4].map((n) => (
        <div
          class="hero-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
          style={`background-image: url('/images/hero/hero-${n}.png')`}
          data-slide={n}
          aria-hidden="true"
        />
      ))
    }
  </div>

  <!-- Overlay oscuro para legibilidad del texto -->
  <div class="absolute inset-0 z-10 bg-black/30" aria-hidden="true"></div>
  <div
    class="relative z-20 container mx-auto px-4 max-w-6xl py-16 md:py-24 lg:py-32"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="flex flex-col gap-6">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 self-start">
          <span
            class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
            aria-hidden="true"></span>
          <span
            class="text-xs font-semibold text-green-700 bg-green-50 border border-green-200 rounded-full px-3 py-1"
          >
            {t("hero.badge")}
          </span>
        </div>

        <!-- Heading -->
        <h1
          class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-white leading-tight"
        >
          {t("hero.title")}
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-white/90 leading-relaxed max-w-lg">
          {t("hero.subtitle")}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a href="tel:9095912273" class="btn-primary">
            {t("hero.cta.primary")}
          </a>
          <a
            href="#services"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg
                    border-2 border-white text-white font-semibold text-sm
                    hover:bg-white hover:text-primary transition-colors duration-200"
          >
            {t("hero.cta.secondary")}
          </a>
        </div>

        <!-- Quick Info -->
        <div class="flex flex-wrap gap-4 pt-4 border-t border-white/30">
          <div class="flex items-center gap-2 text-sm text-white/80">
            <svg
              class="w-4 h-4 text-white/80"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Chino, CA 91710
          </div>
          <div class="flex items-center gap-2 text-sm text-white/80">
            <svg
              class="w-4 h-4 text-white/80"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            (909) 591-CARE
          </div>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-md">
          <!-- Glass container que separa la foto del fondo -->
          <div class="relative rounded-2xl overflow-hidden
            shadow-[0_32px_64px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.15)]
            translate-y-[-8px]">

            <img
              src="/images/Dr_Darlene_Sanchez.jpg"
              alt="Dr. Darlene O. Sanchez with a patient at Loving Hands Animal Hospital"
              class="w-full object-cover aspect-[4/5]"
              width="400"
              height="500"
              loading="eager"
            />
            <!-- Gradiente elegante en la parte inferior -->
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"
              aria-hidden="true"
            >
            </div>

            <!-- Badge flotante -->
            <div
              class="absolute bottom-4 left-4 right-4 backdrop-blur-md bg-black/30 rounded-xl p-3 border border-white/20"
            >
              <p class="text-white font-heading font-bold text-sm">
                Dr. Darlene O. Sanchez, DVM
              </p>
              <p class="text-white/80 text-xs">
                Veterinarian & President · Est. 2014
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll(".hero-slide");
  let current = 0;

  // Mostrar solo la primera imagen al inicio
  slides.forEach((slide, i) => {
    (slide as HTMLElement).style.opacity = i === 0 ? "1" : "0";
  });

  // Cambiar imagen cada 5 segundos
  setInterval(() => {
    (slides[current] as HTMLElement).style.opacity = "0";
    current = (current + 1) % slides.length;
    (slides[current] as HTMLElement).style.opacity = "1";
  }, 5000);
</script>
