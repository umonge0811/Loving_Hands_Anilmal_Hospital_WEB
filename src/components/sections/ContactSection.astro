---
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-4 max-w-6xl">

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="section-title">{t('contact.title')}</h2>
      <p class="section-subtitle">{t('contact.subtitle')}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Contact Info -->
      <div class="flex flex-col gap-6">
        {[
          {
            label: t('contact.address.label'),
            value: t('contact.address.value'),
            href: 'https://maps.google.com/?q=4108+Edison+Ave+Suite+111+Chino+CA+91710',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
          },
          {
            label: t('contact.phone.label'),
            value: t('contact.phone.value'),
            href: 'tel:9095912273',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>`,
          },
          {
            label: t('contact.text.label'),
            value: t('contact.text.value'),
            href: 'sms:9092707277',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`,
          },
          {
            label: t('contact.email.label'),
            value: t('contact.email.value'),
            href: 'mailto:lovinghandsanimalhospital@gmail.com',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>`,
          },
          {
            label: t('contact.hours.label'),
            value: t('contact.hours.value'),
            href: null,
            icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
          },
        ].map(({ label, value, href, icon }) => (
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-accent flex items-center justify-center text-primary flex-shrink-0" aria-hidden="true">
              <Fragment set:html={icon} />
            </div>
            <div>
              <p class="text-xs font-semibold text-muted uppercase tracking-wide">{label}</p>
              {href ? (
                <a href={href} class="text-gray-900 hover:text-primary transition-colors font-medium text-sm mt-0.5 block break-all">
                  {value}
                </a>
              ) : (
                <p class="text-gray-900 font-medium text-sm mt-0.5">{value}</p>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Google Map Embed -->
      <div class="rounded-2xl overflow-hidden shadow-md aspect-video lg:aspect-square">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3307.9!2d-117.688!3d34.012!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s4108+Edison+Ave+Suite+111+Chino+CA+91710!5e0!3m2!1sen!2sus!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Loving Hands Animal Hospital location map"
          class="w-full h-full"
        ></iframe>
      </div>

    </div>
  </div>
</section>
