---
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    name: 'Jessica M.',
    rating: 5,
    text: 'Dr. Sanchez is amazing! She took the time to explain everything about my dog\'s condition. The staff is so warm and welcoming. Best vet in Chino!',
    pet: 'Dog owner',
  },
  {
    name: 'Carlos R.',
    rating: 5,
    text: 'We had an emergency with our cat on a Sunday and they were open 24 hours. Dr. Sanchez saved our cat\'s life. Forever grateful.',
    pet: 'Cat owner',
  },
  {
    name: 'Maria L.',
    rating: 5,
    text: 'I love that they offer holistic medicine alongside traditional treatments. Dr. Sanchez truly cares about the whole wellbeing of your pet.',
    pet: 'Dog owner',
  },
];
---

<section class="py-16 md:py-24 bg-accent">
  <div class="container mx-auto px-4 max-w-6xl">

    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="section-title">{t('testimonials.title')}</h2>
      <p class="section-subtitle">{t('testimonials.subtitle')}</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(({ name, rating, text, pet }) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm flex flex-col gap-4 hover:shadow-md transition-shadow duration-300">

          <!-- Stars -->
          <div class="flex gap-1" aria-label={`${rating} out of 5 stars`}>
            {Array.from({ length: rating }).map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Text -->
          <p class="text-gray-600 text-sm leading-relaxed flex-grow">
            "{text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
              <span class="text-primary font-bold text-sm">{name[0]}</span>
            </div>
            <div>
              <p class="font-semibold text-sm text-gray-900">{name}</p>
              <p class="text-xs text-muted">{pet}</p>
            </div>
            <!-- Yelp badge -->
            <span class="ml-auto text-xs text-muted font-medium">Yelp ⭐</span>
          </div>

        </div>
      ))}
    </div>

    <!-- Link a Yelp -->
    <div class="text-center mt-10">
      <a
        href="https://www.yelp.com/biz/loving-hands-animal-hospital-chino"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-sm"
      >
      {t('testimonials.yelp_cta')}

      </a>
    </div>

  </div>
</section>
