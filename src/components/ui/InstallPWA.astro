---
// Shows a PWA install banner when the browser fires beforeinstallprompt
---

<div id="pwa-banner" class="hidden fixed bottom-4 left-4 right-4 md:left-auto md:right-6 md:w-80 z-50">
  <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-4 flex items-center gap-4">
    <img
      src="/images/logo_Loving_Hands.jpg"
      alt="Loving Hands"
      class="w-12 h-12 rounded-xl object-cover flex-shrink-0 shadow-sm"
    />
    <div class="flex-1 min-w-0">
      <p class="text-sm font-bold text-gray-900">Install App</p>
      <p class="text-xs text-muted leading-snug">Add Loving Hands to your home screen</p>
    </div>
    <div class="flex flex-col gap-1.5 flex-shrink-0">
      <button
        id="pwa-install-btn"
        class="px-3 py-1.5 rounded-lg bg-primary text-white text-xs font-semibold hover:bg-primary-dark transition-colors"
      >
        Install
      </button>
      <button
        id="pwa-dismiss-btn"
        class="px-3 py-1.5 rounded-lg bg-gray-100 text-gray-500 text-xs font-medium hover:bg-gray-200 transition-colors"
      >
        Not now
      </button>
    </div>
  </div>
</div>

<script>
  let deferredPrompt: any = null;
  const banner = document.getElementById('pwa-banner');
  const installBtn = document.getElementById('pwa-install-btn');
  const dismissBtn = document.getElementById('pwa-dismiss-btn');

  // Browser fires this when the app is installable
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;

    // Only show if user hasn't dismissed before
    if (!sessionStorage.getItem('pwa-dismissed')) {
      banner?.classList.remove('hidden');
      // Animate in
      setTimeout(() => banner?.classList.add('animate-fade-in'), 100);
    }
  });

  installBtn?.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    deferredPrompt = null;
    banner?.classList.add('hidden');
    if (outcome === 'accepted') {
      console.log('PWA installed');
    }
  });

  dismissBtn?.addEventListener('click', () => {
    banner?.classList.add('hidden');
    sessionStorage.setItem('pwa-dismissed', '1');
  });

  // Hide banner if already installed
  window.addEventListener('appinstalled', () => {
    banner?.classList.add('hidden');
    deferredPrompt = null;
  });
</script>
