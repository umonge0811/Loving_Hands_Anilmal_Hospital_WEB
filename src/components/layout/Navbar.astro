---
import { getLangFromUrl, useTranslations, getAlternateLangUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateLangUrl = getAlternateLangUrl(Astro.url, lang === 'en' ? 'es' : 'en');

const navLinks = [
{ key: 'nav.home' as const, href: lang === 'en' ? '/#home' : '/es/#home' },
  { key: 'nav.services' as const, href: lang === 'en' ? '/#services' : '/es/#services' },
  { key: 'nav.team' as const,     href: lang === 'en' ? '/#team' : '/es/#team' },
  { key: 'nav.contact' as const,  href: lang === 'en' ? '/#contact' : '/es/#contact' },
];
---

<header id="navbar" class="sticky top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm transition-all duration-300">
  <nav class="container mx-auto px-4 max-w-6xl" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href={lang === 'en' ? '/' : '/es/'} class="flex items-center gap-3 group">
        <img
          src="/images/logo_Loving_Hands.jpg"
          alt="Loving Hands Animal Hospital"
          class="h-10 w-auto"
          width="70"
          height="70"
        />
        <span class="font-heading font-bold text-primary text-sm leading-tight hidden sm:block">
          Loving Hands<br />
          <span class="text-xs font-body font-semibold tracking-widest uppercase text-secondary">
            Animal Hospital
          </span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-6" role="list">
        {navLinks.map(({ key, href }) => (
        <li>
          <a
            href={href}
            data-navlink
            class="relative text-sm font-medium text-gray-700 hover:text-primary transition-colors duration-200
                   after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px]
                   after:bg-primary after:transition-all after:duration-300
                   [&.active]:text-primary [&.active]:after:w-full"
          >
            {t(key)}
          </a>
        </li>
      ))}
      
      </ul>

      <!-- Right side: Language switcher + CTA -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <a
          href={alternateLangUrl}
          class="text-xs font-semibold text-primary border border-primary rounded-md px-2 py-1 hover:bg-primary hover:text-white transition-colors duration-200"
          aria-label={lang === 'en' ? 'Ver en Español' : 'View in English'}
        >
          {t('nav.lang')}
        </a>

        <!-- Portal Button (desktop only) -->
        <a
          href={lang === 'en' ? '/portal/login' : '/es/portal/login'}
          class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-primary border border-primary rounded-md px-3 py-1.5 hover:bg-primary hover:text-white transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          {t('nav.portal')}
        </a>

        <!-- Admin Button (desktop only) -->
        <a
          href={lang === 'en' ? '/admin/login' : '/es/admin/login'}
          class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-white bg-primary-dark rounded-md px-3 py-1.5 hover:bg-primary transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          {t('nav.admin')}
        </a>

        <!-- CTA Button (desktop only) -->
        <a href={`tel:9095912273`} class="btn-primary hidden md:inline-flex text-xs px-4 py-2">
          {t('nav.book')}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map(({ key, href }) => (
          <li>
            <a
              href={href}
              class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-accent hover:text-primary transition-colors"
            >
              {t(key)}
            </a>
          </li>
        ))}
        <li>
          <a
            href={lang === 'en' ? '/portal/login' : '/es/portal/login'}
            class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-primary border border-primary hover:bg-primary hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {t('nav.portal')}
          </a>
          <a
            href={lang === 'en' ? '/admin/login' : '/es/admin/login'}
            class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-white bg-primary-dark hover:bg-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            {t('nav.admin')}
          </a>
        </li>
        <li class="pt-1">
          <a href="tel:9095912273" class="btn-primary w-full text-center text-xs">
            {t('nav.book')}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle — plain JS, no framework needed
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
  });

    // ─── Indicador activo por seccion ───────────────────────────
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('[data-navlink]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        // Quitar active de todos
        navLinks.forEach(link => link.classList.remove('active'));

        // Agregar active al link que corresponde a la seccion visible
        const activeLink = document.querySelector(
          `[data-navlink][href*="#${entry.target.id}"]`
        );
        activeLink?.classList.add('active');
      }
    });
  }, {
    rootMargin: '-40% 0px -50% 0px' // activa cuando la seccion esta en el centro de la pantalla
  });

  sections.forEach(section => observer.observe(section));
    // Activar Home por defecto si el scroll esta arriba
    window.addEventListener('scroll', () => {
    if (window.scrollY < 100) {
      navLinks.forEach(link => link.classList.remove('active'));
      document.querySelector('[data-navlink][href*="#home"]')
        ?.classList.add('active');
    }
  }, { passive: true });

  // ─── Navbar blur al scroll ───────────────────────────────────
  const navbar = document.getElementById('navbar');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('bg-white/80', 'shadow-md');
      navbar?.classList.remove('bg-white/95', 'shadow-sm');
    } else {
      navbar?.classList.add('bg-white/95', 'shadow-sm');
      navbar?.classList.remove('bg-white/80', 'shadow-md');
    }
  }, { passive: true });

</script>
