---
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="bg-red-700 text-white py-2 px-4">
  <div class="container mx-auto max-w-6xl flex flex-col sm:flex-row items-center justify-between gap-2">
    
    <div class="flex items-center gap-3">
      <!-- Icono pulsante de emergencia -->
      <span class="relative flex h-3 w-3 flex-shrink-0">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-white"></span>
      </span>
      <div class="flex flex-col sm:flex-row sm:items-center sm:gap-2">
        <span class="font-heading font-bold text-sm">
          {t('emergency.banner.text')}
        </span>
        <span class="hidden sm:inline text-white/60">·</span>
        <span class="text-xs text-white/90">
          {t('emergency.banner.sub')}
        </span>
      </div>
    </div>

    <a
      href="tel:9095912273"
      class="flex-shrink-0 text-xs font-bold bg-white text-red-700 px-3 py-1 rounded-full
             hover:bg-red-50 transition-colors duration-200"
    >
      {t('emergency.banner.cta')} →
    </a>

  </div>
</div>
