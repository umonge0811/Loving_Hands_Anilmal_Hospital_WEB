---
import '@/styles/global.css';
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  activePage?: 'dashboard' | 'pets' | 'appointments' | 'profile';
}

const { title, description = '', lang, activePage = 'dashboard' } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'es' ? '/es' : '';
const altLang = lang === 'es' ? 'en' : 'es';
const altBase = altLang === 'es' ? '/es' : '';

const navLinks = [
  {
    key: 'dashboard',
    label: t('portal.nav.dashboard'),
    href: `${base}/portal/dashboard`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  },
  {
    key: 'pets',
    label: t('portal.nav.pets'),
    href: `${base}/portal/pets`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
  },
  {
    key: 'appointments',
    label: t('portal.nav.appointments'),
    href: `${base}/portal/appointments`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  },
  {
    key: 'profile',
    label: t('portal.nav.profile'),
    href: `${base}/portal/profile`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`,
  },
];
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/jpeg" href="/images/logo_Loving_Hands.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="robots" content="noindex, nofollow" />
  </head>

  <body class="bg-gray-50 font-body text-gray-800">

    <!-- Mobile top bar -->
    <header class="lg:hidden fixed top-0 inset-x-0 z-40 bg-white border-b border-gray-200 flex items-center justify-between px-4 h-14">
      <a href={`${base}/portal/dashboard`} class="flex items-center gap-2">
        <img src="/images/logo_Loving_Hands.jpg" alt="Loving Hands" class="h-8 w-8 rounded-full object-cover" />
        <span class="font-heading font-bold text-primary text-sm leading-tight">Loving Hands</span>
      </a>
      <div class="flex items-center gap-3">
        <a href={`${altBase}/portal/${activePage}`} class="text-xs font-medium text-muted hover:text-primary transition-colors px-2 py-1 rounded border border-gray-200">
          {lang === 'es' ? 'EN' : 'ES'}
        </a>
        <button id="mobile-menu-btn" aria-label="Open menu" class="p-2 rounded-lg hover:bg-accent transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile sidebar overlay -->
    <div id="mobile-overlay" class="lg:hidden fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/40" id="overlay-bg"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-64 bg-white shadow-xl flex flex-col">
        <div class="flex items-center justify-between p-4 border-b border-gray-100">
          <span class="font-heading font-bold text-primary">Menu</span>
          <button id="close-menu-btn" class="p-1 rounded hover:bg-accent transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="flex-1 py-4 px-3 space-y-1">
          {navLinks.map(link => (
            <a href={link.href}
               class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors ${activePage === link.key ? 'bg-primary text-white' : 'text-gray-600 hover:bg-accent hover:text-primary'}`}>
              <span class="flex-shrink-0" set:html={link.icon} />
              {link.label}
            </a>
          ))}
        </nav>
        <div class="p-4 border-t border-gray-100 space-y-2">
          <a href="/" class="flex items-center gap-2 text-xs text-muted hover:text-primary transition-colors py-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            {t('portal.nav.backToSite')}
          </a>
          <a href={`${base}/portal/login`} class="flex items-center gap-2 text-xs text-red-600 hover:text-red-700 transition-colors py-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
            {t('portal.nav.logout')}
          </a>
        </div>
      </aside>
    </div>

    <div class="flex min-h-screen">

      <!-- Desktop Sidebar -->
      <aside class="hidden lg:flex flex-col fixed left-0 top-0 bottom-0 w-60 bg-white border-r border-gray-200 z-30">

        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-5 border-b border-gray-100">
          <img src="/images/logo_Loving_Hands.jpg" alt="Loving Hands Animal Hospital" class="h-10 w-10 rounded-full object-cover shadow-sm" />
          <div>
            <p class="font-heading font-bold text-primary text-sm leading-tight">Loving Hands</p>
            <p class="text-xs text-muted">Animal Hospital</p>
          </div>
        </div>

        <!-- User card -->
        <div class="mx-3 mt-4 mb-2 bg-accent rounded-xl px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
            JD
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-800 truncate">Jane Doe</p>
            <p class="text-xs text-muted truncate">jane@email.com</p>
          </div>
        </div>

        <!-- Nav links -->
        <nav class="flex-1 py-3 px-3 space-y-0.5">
          {navLinks.map(link => (
            <a href={link.href}
               class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors ${activePage === link.key ? 'bg-primary text-white shadow-sm' : 'text-gray-600 hover:bg-accent hover:text-primary'}`}>
              <span class="flex-shrink-0" set:html={link.icon} />
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Bottom links -->
        <div class="px-3 pb-4 space-y-0.5 border-t border-gray-100 pt-3">
          <!-- Language switcher -->
          <a href={`${altBase}/portal/${activePage}`}
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-muted hover:bg-accent hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
            </svg>
            {lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
          </a>

          <a href="/"
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-muted hover:bg-accent hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {t('portal.nav.backToSite')}
          </a>

          <a href={`${base}/portal/login`}
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-red-500 hover:bg-red-50 hover:text-red-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            {t('portal.nav.logout')}
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 lg:ml-60 pt-14 lg:pt-0 min-h-screen">
        <slot />
      </main>

    </div>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const overlay = document.getElementById('mobile-overlay');
      const overlayBg = document.getElementById('overlay-bg');
      const closeBtn = document.getElementById('close-menu-btn');

      function openMenu() { overlay?.classList.remove('hidden'); }
      function closeMenu() { overlay?.classList.add('hidden'); }

      btn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlayBg?.addEventListener('click', closeMenu);
    </script>
  </body>
</html>
