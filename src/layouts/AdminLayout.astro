---
import '@/styles/global.css';
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  title: string;
  lang: Lang;
  activePage?: 'dashboard' | 'appointments' | 'clients' | 'records' | 'services' | 'staff';
}

const { title, lang, activePage = 'dashboard' } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'es' ? '/es' : '';
const altBase = lang === 'es' ? '' : '/es';

const navLinks = [
  {
    key: 'dashboard',
    label: t('admin.nav.dashboard'),
    href: `${base}/admin/dashboard`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  },
  {
    key: 'appointments',
    label: t('admin.nav.appointments'),
    href: `${base}/admin/appointments`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
  },
  {
    key: 'clients',
    label: t('admin.nav.clients'),
    href: `${base}/admin/clients`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
  {
    key: 'records',
    label: t('admin.nav.records'),
    href: `${base}/admin/records`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
  },
  {
    key: 'services',
    label: t('admin.nav.services'),
    href: `${base}/admin/services`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
  },
  {
    key: 'staff',
    label: t('admin.nav.staff'),
    href: `${base}/admin/staff`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
];
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href="/images/logo_Loving_Hands.jpg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#5C1515" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Loving Hands Admin" />
    <link rel="apple-touch-icon" href="/images/logo_Loving_Hands.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="robots" content="noindex, nofollow" />
  </head>

  <body class="bg-gray-100 font-body text-gray-800">

    <!-- Mobile top bar -->
    <header class="lg:hidden fixed top-0 inset-x-0 z-40 bg-primary text-white flex items-center justify-between px-4 h-14">
      <a href={`${base}/admin/dashboard`} class="flex items-center gap-2">
        <img src="/images/logo_Loving_Hands.jpg" alt="Loving Hands" class="h-7 w-7 rounded-full object-cover ring-2 ring-white/30" />
        <span class="font-heading font-bold text-sm">Admin Panel</span>
      </a>
      <button id="mobile-menu-btn" aria-label="Open menu" class="p-2 rounded-lg hover:bg-white/10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </header>

    <!-- Mobile drawer -->
    <div id="mobile-overlay" class="lg:hidden fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/50" id="overlay-bg"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-64 bg-primary-dark text-white flex flex-col shadow-2xl">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/10">
          <span class="font-heading font-bold text-sm">Admin Panel</span>
          <button id="close-menu-btn" class="p-1 rounded hover:bg-white/10 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="flex-1 py-4 px-3 space-y-0.5">
          {navLinks.map(link => (
            <a href={link.href}
               class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors ${activePage === link.key ? 'bg-white/20 text-white' : 'text-white/70 hover:bg-white/10 hover:text-white'}`}>
              <span class="flex-shrink-0" set:html={link.icon} />
              {link.label}
            </a>
          ))}
        </nav>
        <div class="p-4 border-t border-white/10 space-y-1">
          <a href={`${altBase}/admin/${activePage}`} class="flex items-center gap-2 text-xs text-white/60 hover:text-white transition-colors py-1.5 px-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" /></svg>
            {lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
          </a>
          <a href={`${base}/admin/login`} class="flex items-center gap-2 text-xs text-red-300 hover:text-red-200 transition-colors py-1.5 px-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
            {t('admin.nav.logout')}
          </a>
        </div>
      </aside>
    </div>

    <div class="flex min-h-screen">

      <!-- Desktop Sidebar — dark brand color -->
      <aside class="hidden lg:flex flex-col fixed left-0 top-0 bottom-0 w-60 bg-primary-dark text-white z-30">

        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-5 border-b border-white/10">
          <img src="/images/logo_Loving_Hands.jpg" alt="Loving Hands Animal Hospital" class="h-10 w-10 rounded-full object-cover ring-2 ring-white/30" />
          <div>
            <p class="font-heading font-bold text-sm leading-tight">Loving Hands</p>
            <p class="text-xs text-white/50 uppercase tracking-wider">Admin Panel</p>
          </div>
        </div>

        <!-- Staff card -->
        <div class="mx-3 mt-4 mb-2 bg-white/10 rounded-xl px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
            DS
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-white truncate">Dr. Sanchez</p>
            <p class="text-xs text-white/50 truncate">{t('admin.nav.role.vet')}</p>
          </div>
        </div>

        <!-- Nav links -->
        <nav class="flex-1 py-3 px-3 space-y-0.5">
          {navLinks.map(link => (
            <a href={link.href}
               class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors ${activePage === link.key ? 'bg-white/20 text-white shadow-sm' : 'text-white/60 hover:bg-white/10 hover:text-white'}`}>
              <span class="flex-shrink-0" set:html={link.icon} />
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Bottom -->
        <div class="px-3 pb-4 border-t border-white/10 pt-3 space-y-0.5">
          <a href={`${altBase}/admin/${activePage}`}
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-white/50 hover:bg-white/10 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
            </svg>
            {lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
          </a>

          <a href="/"
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-white/50 hover:bg-white/10 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {t('admin.nav.backToSite')}
          </a>

          <a href={`${base}/admin/login`}
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-red-300 hover:bg-red-900/30 hover:text-red-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            {t('admin.nav.logout')}
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 lg:ml-60 pt-14 lg:pt-0 min-h-screen">
        <slot />
      </main>

    </div>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const overlay = document.getElementById('mobile-overlay');
      const overlayBg = document.getElementById('overlay-bg');
      const closeBtn = document.getElementById('close-menu-btn');
      const openMenu = () => overlay?.classList.remove('hidden');
      const closeMenu = () => overlay?.classList.add('hidden');
      btn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlayBg?.addEventListener('click', closeMenu);
    </script>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
  </body>
</html>
