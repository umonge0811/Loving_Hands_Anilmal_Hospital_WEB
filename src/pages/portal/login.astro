---
import '@/styles/global.css';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t('meta.portal.login.title')}</title>
    <meta name="description" content={t('meta.portal.login.description')} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/jpeg" href="/images/logo_Loving_Hands.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="font-body bg-accent min-h-screen flex flex-col">

    <!-- Language toggle -->
    <div class="absolute top-4 right-4 z-10">
      <a href="/es/portal/login"
         class="text-sm font-medium text-muted hover:text-primary transition-colors px-3 py-1.5 rounded-lg border border-gray-200 bg-white shadow-sm">
        Español
      </a>
    </div>

    <!-- Back to site -->
    <div class="absolute top-4 left-4 z-10">
      <a href="/" class="flex items-center gap-1.5 text-sm text-muted hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {t('portal.nav.backToSite')}
      </a>
    </div>

    <div class="flex-1 flex items-center justify-center px-4 py-16">
      <div class="w-full max-w-md">

        <!-- Card -->
        <div class="bg-white rounded-3xl shadow-xl p-8 md:p-10">

          <!-- Logo & title -->
          <div class="text-center mb-8">
            <img
              src="/images/logo_Loving_Hands.jpg"
              alt="Loving Hands Animal Hospital"
              class="w-20 h-20 rounded-full object-cover mx-auto mb-4 shadow-md ring-4 ring-accent"
            />
            <h1 class="font-heading text-2xl font-bold text-primary mb-1">
              {t('portal.login.title')}
            </h1>
            <p class="text-sm text-muted">{t('portal.login.subtitle')}</p>
          </div>

          <!-- Demo badge -->
          <div class="flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-xl px-4 py-2.5 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-xs text-amber-700">{t('portal.login.demo')}</p>
          </div>

          <!-- SSO Button -->
          <a href="/portal/dashboard"
             class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-xl bg-primary text-white font-semibold text-sm hover:bg-primary-dark transition-colors shadow-sm mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            {t('portal.login.sso')}
          </a>

          <!-- Divider -->
          <div class="flex items-center gap-3 mb-5">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-muted uppercase tracking-wide">{t('portal.login.or')}</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <!-- Email/Password form -->
          <form class="space-y-4" action="/portal/dashboard">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">
                {t('portal.login.email')}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                placeholder="you@email.com"
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
              />
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="password" class="block text-sm font-medium text-gray-700">
                  {t('portal.login.password')}
                </label>
                <a href="#" class="text-xs text-primary hover:underline">{t('portal.login.forgot')}</a>
              </div>
              <input
                type="password"
                id="password"
                name="password"
                autocomplete="current-password"
                placeholder="••••••••"
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
              />
            </div>

            <a href="/portal/dashboard"
               class="flex items-center justify-center w-full px-4 py-3 rounded-xl bg-secondary text-white font-semibold text-sm hover:bg-secondary-light transition-colors shadow-sm">
              {t('portal.login.submit')}
            </a>
          </form>

          <!-- Register link -->
          <p class="text-center text-sm text-muted mt-6">
            {t('portal.login.noAccount')}
            {' '}
            <a href="#" class="text-primary font-semibold hover:underline">
              {t('portal.login.register')}
            </a>
          </p>
        </div>

        <!-- Footer note -->
        <p class="text-center text-xs text-muted mt-6">
          &copy; {new Date().getFullYear()} Loving Hands Animal Hospital
        </p>
      </div>
    </div>

  </body>
</html>
