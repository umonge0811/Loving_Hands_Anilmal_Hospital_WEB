---
import PortalLayout from '@/layouts/PortalLayout.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const mockUser = { name: 'Jane' };

const stats = [
  {
    label: t('portal.dashboard.stat.pets'),
    value: '3',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    color: 'text-rose-500 bg-rose-50',
  },
  {
    label: t('portal.dashboard.stat.upcoming'),
    value: '2',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    color: 'text-primary bg-primary/10',
  },
  {
    label: t('portal.dashboard.stat.lastVisit'),
    value: 'Apr 10',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
    color: 'text-emerald-600 bg-emerald-50',
  },
];

const upcomingAppts = [
  { pet: 'Bella', petIcon: '🐶', service: 'Wellness Exam', date: 'Apr 28, 2026', time: '10:00 AM', vet: 'Dr. Sanchez' },
  { pet: 'Max', petIcon: '🐱', service: 'Dental Cleaning', date: 'May 5, 2026', time: '2:30 PM', vet: 'Dr. Sanchez' },
];

const quickActions = [
  { label: t('portal.dashboard.action.book'), href: '/portal/appointments', icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>`, color: 'bg-primary text-white hover:bg-primary-dark' },
  { label: t('portal.dashboard.action.pets'), href: '/portal/pets', icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`, color: 'bg-secondary text-white hover:bg-secondary-light' },
  { label: t('portal.dashboard.action.history'), href: '/portal/pets', icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`, color: 'bg-accent text-primary hover:bg-secondary/20' },
  { label: t('portal.dashboard.action.profile'), href: '/portal/profile', icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`, color: 'bg-accent text-primary hover:bg-secondary/20' },
];
---

<PortalLayout
  lang={lang}
  title={t('meta.portal.dashboard.title')}
  activePage="dashboard"
>
  <div class="p-6 md:p-8 max-w-5xl mx-auto">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="font-heading text-2xl md:text-3xl font-bold text-gray-900">
        {t('portal.dashboard.welcome', { name: mockUser.name })}
      </h1>
      <p class="text-muted mt-1">{t('portal.dashboard.subtitle')}</p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      {stats.map(stat => (
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex items-center gap-4">
          <div class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 ${stat.color}`} set:html={stat.icon} />
          <div>
            <p class="text-2xl font-bold text-gray-900">{stat.value}</p>
            <p class="text-xs text-muted">{stat.label}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Upcoming Appointments -->
      <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
          <h2 class="font-heading font-semibold text-gray-900">{t('portal.dashboard.upcoming.title')}</h2>
          <a href="/portal/appointments" class="text-xs font-medium text-primary hover:underline">
            {t('portal.dashboard.viewAll')} →
          </a>
        </div>

        <div class="divide-y divide-gray-50">
          {upcomingAppts.map(appt => (
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors">
              <div class="w-10 h-10 rounded-xl bg-accent flex items-center justify-center text-xl flex-shrink-0">
                {appt.petIcon}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900">{appt.service}</p>
                <p class="text-xs text-muted">{appt.pet} · {appt.vet}</p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-sm font-medium text-gray-700">{appt.date}</p>
                <p class="text-xs text-muted">{appt.time}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
          <a href="/portal/appointments"
             class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl border-2 border-primary text-primary text-sm font-semibold hover:bg-primary hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            {t('portal.dashboard.book')}
          </a>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="font-heading font-semibold text-gray-900">{t('portal.dashboard.quickActions')}</h2>
        </div>
        <div class="p-4 grid grid-cols-2 gap-3">
          {quickActions.map(action => (
            <a href={action.href}
               class={`flex flex-col items-center gap-2 p-4 rounded-xl text-center text-xs font-semibold transition-colors ${action.color}`}>
              <span set:html={action.icon} />
              {action.label}
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</PortalLayout>
