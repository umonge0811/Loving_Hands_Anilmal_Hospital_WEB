---
import '@/styles/global.css';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t('meta.admin.login.title')}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/jpeg" href="/images/logo_Loving_Hands.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="font-body min-h-screen flex flex-col" style="background: linear-gradient(135deg, #5C1515 0%, #7B1D1D 60%, #A63232 100%);">

    <div class="absolute top-4 right-4">
      <a href="/es/admin/login" class="text-xs font-medium text-white/70 hover:text-white transition-colors px-3 py-1.5 rounded-lg border border-white/20 hover:border-white/40">
        Español
      </a>
    </div>

    <div class="absolute top-4 left-4">
      <a href="/" class="flex items-center gap-1.5 text-sm text-white/60 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {t('admin.nav.backToSite')}
      </a>
    </div>

    <div class="flex-1 flex items-center justify-center px-4 py-16">
      <div class="w-full max-w-md">

        <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-10">

          <!-- Header -->
          <div class="text-center mb-8">
            <div class="w-16 h-16 rounded-2xl bg-primary-dark flex items-center justify-center mx-auto mb-4 shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h1 class="font-heading text-2xl font-bold text-primary mb-1">{t('admin.login.title')}</h1>
            <p class="text-sm text-muted max-w-xs mx-auto">{t('admin.login.subtitle')}</p>
          </div>

          <!-- Demo badge -->
          <div class="flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-xl px-4 py-2.5 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-xs text-amber-700">{t('admin.login.demo')}</p>
          </div>

          <!-- SSO -->
          <a href="/admin/dashboard"
             class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-xl bg-primary text-white font-semibold text-sm hover:bg-primary-dark transition-colors shadow-sm mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            {t('admin.login.sso')}
          </a>

          <div class="flex items-center gap-3 mb-5">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-muted uppercase tracking-wide">{t('admin.login.or')}</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <!-- Form -->
          <form class="space-y-4" action="/admin/dashboard">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">{t('admin.login.email')}</label>
              <input type="email" id="email" name="email" autocomplete="email" placeholder="doctor@lovinghands.com"
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
            </div>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="password" class="block text-sm font-medium text-gray-700">{t('admin.login.password')}</label>
                <a href="#" class="text-xs text-primary hover:underline">{t('admin.login.forgot')}</a>
              </div>
              <input type="password" id="password" name="password" autocomplete="current-password" placeholder="••••••••"
                class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
            </div>
            <a href="/admin/dashboard"
               class="flex items-center justify-center w-full px-4 py-3 rounded-xl bg-primary-dark text-white font-semibold text-sm hover:bg-primary transition-colors shadow-sm">
              {t('admin.login.submit')}
            </a>
          </form>

          <!-- Divider between portals -->
          <div class="mt-8 pt-6 border-t border-gray-100 text-center">
            <p class="text-xs text-muted mb-2">Are you a client?</p>
            <a href="/portal/login" class="text-xs font-semibold text-primary hover:underline">Go to Client Portal →</a>
          </div>
        </div>

        <p class="text-center text-xs text-white/40 mt-6">
          &copy; {new Date().getFullYear()} Loving Hands Animal Hospital
        </p>
      </div>
    </div>

  </body>
</html>
