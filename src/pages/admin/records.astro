---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { useTranslations } from '@/i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const records = [
  {
    id: 1,
    date: 'Apr 22, 2026',
    pet: 'Bella',       petIcon: '🐶', species: 'Dog',
    client: 'Jane Doe',
    diagnosis: 'Routine wellness — healthy weight, vaccinations up to date',
    treatment: 'Annual vaccines (DHPP, Rabies), heartworm test — negative',
    vet: 'Dr. Sanchez',
    nextVisit: 'Apr 2027',
    weight: '62 lbs',
    tags: ['Wellness', 'Vaccines'],
  },
  {
    id: 2,
    date: 'Apr 22, 2026',
    pet: 'Luna',        petIcon: '🐱', species: 'Cat',
    client: 'Carlos Rivera',
    diagnosis: 'Feline upper respiratory infection — mild',
    treatment: 'Doxycycline 50mg BID × 10 days, saline nasal flush',
    vet: 'Dr. Sanchez',
    nextVisit: 'May 5, 2026',
    weight: '9 lbs',
    tags: ['Illness', 'Prescription'],
  },
  {
    id: 3,
    date: 'Apr 10, 2026',
    pet: 'Bella',       petIcon: '🐶', species: 'Dog',
    client: 'Jane Doe',
    diagnosis: 'Skin allergy — environmental (pollen season)',
    treatment: 'Apoquel 16mg QD, medicated shampoo 2×/week',
    vet: 'Dr. Sanchez',
    nextVisit: 'May 10, 2026',
    weight: '63 lbs',
    tags: ['Allergy', 'Prescription'],
  },
  {
    id: 4,
    date: 'Mar 22, 2026',
    pet: 'Max',         petIcon: '🐱', species: 'Cat',
    client: 'Jane Doe',
    diagnosis: 'Dental disease grade II — tartar buildup',
    treatment: 'Professional dental cleaning under anesthesia, 2 extractions (premolars)',
    vet: 'Dr. Sanchez',
    nextVisit: 'Mar 2027',
    weight: '10 lbs',
    tags: ['Dental', 'Surgery'],
  },
  {
    id: 5,
    date: 'Feb 5, 2026',
    pet: 'Coco',        petIcon: '🦜', species: 'Bird',
    client: 'John Smith',
    diagnosis: 'Annual wellness — excellent condition',
    treatment: 'Wing and nail trim, beak check — normal',
    vet: 'Dr. Sanchez',
    nextVisit: 'Feb 2027',
    weight: '3.2 oz',
    tags: ['Wellness', 'Exotic'],
  },
  {
    id: 6,
    date: 'Jan 28, 2026',
    pet: 'Rocky',       petIcon: '🐶', species: 'Dog',
    client: 'Maria Lopez',
    diagnosis: 'ACL tear — right stifle, grade III',
    treatment: 'TPLO surgery performed, post-op care protocol, 8-week rehab plan',
    vet: 'Dr. Sanchez',
    nextVisit: 'Apr 28, 2026',
    weight: '55 lbs',
    tags: ['Surgery', 'Follow-up'],
  },
];

const tagColors: Record<string, string> = {
  Wellness:    'bg-emerald-100 text-emerald-700',
  Vaccines:    'bg-blue-100 text-blue-700',
  Illness:     'bg-red-100 text-red-600',
  Prescription:'bg-amber-100 text-amber-700',
  Allergy:     'bg-orange-100 text-orange-700',
  Dental:      'bg-indigo-100 text-indigo-700',
  Surgery:     'bg-purple-100 text-purple-700',
  Exotic:      'bg-teal-100 text-teal-700',
  'Follow-up': 'bg-gray-100 text-gray-600',
};
---

<AdminLayout lang={lang} title={t('meta.admin.records.title')} activePage="records">
  <div class="p-6 md:p-8 max-w-6xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-heading text-2xl md:text-3xl font-bold text-gray-900">{t('admin.records.title')}</h1>
        <p class="text-muted mt-1">{t('admin.records.subtitle')}</p>
      </div>
      <button class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors shadow-sm self-start">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        {t('admin.records.new')}
      </button>
    </div>

    <!-- Search + stats row -->
    <div class="flex flex-col md:flex-row gap-4 mb-8">
      <div class="relative flex-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="search" id="search-input" placeholder={t('admin.records.search')}
          class="w-full pl-11 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors shadow-sm" />
      </div>
      <div class="flex gap-3">
        {[
          { label: 'Total Records', value: String(records.length) },
          { label: 'This Month', value: '3' },
          { label: 'Patients', value: '5' },
        ].map(s => (
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-4 py-2.5 text-center min-w-[80px]">
            <p class="text-lg font-bold text-primary">{s.value}</p>
            <p class="text-xs text-muted">{s.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Records list -->
    <div class="space-y-4" id="records-list">
      {records.map(record => (
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow record-row">

          <!-- Record header -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50/50">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-accent flex items-center justify-center text-xl flex-shrink-0">
                {record.petIcon}
              </div>
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <p class="text-sm font-bold text-gray-900 record-pet">{record.pet}</p>
                  <span class="text-xs text-muted">·</span>
                  <p class="text-sm text-muted record-client">{record.client}</p>
                </div>
                <div class="flex items-center gap-2 mt-0.5">
                  <p class="text-xs text-muted">{record.species} · {record.weight}</p>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-3 flex-wrap">
              <!-- Tags -->
              <div class="flex gap-1.5 flex-wrap">
                {record.tags.map(tag => (
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${tagColors[tag] ?? 'bg-gray-100 text-gray-600'}`}>{tag}</span>
                ))}
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-xs font-semibold text-gray-700">{record.date}</p>
                <p class="text-xs text-muted">{record.vet}</p>
              </div>
            </div>
          </div>

          <!-- Record body -->
          <div class="px-6 py-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-1">{t('admin.records.col.diagnosis')}</p>
              <p class="text-sm text-gray-800 leading-relaxed">{record.diagnosis}</p>
            </div>
            <div>
              <p class="text-xs font-semibold text-muted uppercase tracking-wide mb-1">{t('admin.records.col.treatment')}</p>
              <p class="text-sm text-gray-800 leading-relaxed">{record.treatment}</p>
            </div>
          </div>

          <!-- Record footer -->
          <div class="flex items-center justify-between px-6 py-3 bg-gray-50/50 border-t border-gray-100">
            <div class="flex items-center gap-1.5 text-xs text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>Next visit: <strong class="text-gray-700">{record.nextVisit}</strong></span>
            </div>
            <div class="flex items-center gap-3">
              <button class="text-xs font-semibold text-primary hover:underline">{t('admin.records.action.view')}</button>
              <button class="text-xs font-semibold text-gray-500 hover:underline">{t('admin.records.action.edit')}</button>
              <button class="flex items-center gap-1 text-xs font-semibold text-muted hover:text-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
                {t('admin.records.action.print')}
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</AdminLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const rows = document.querySelectorAll<HTMLElement>('.record-row');

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    rows.forEach(row => {
      const pet    = row.querySelector('.record-pet')?.textContent?.toLowerCase() ?? '';
      const client = row.querySelector('.record-client')?.textContent?.toLowerCase() ?? '';
      row.style.display = (pet.includes(q) || client.includes(q)) ? '' : 'none';
    });
  });
</script>
